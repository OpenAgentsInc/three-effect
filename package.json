{
  "name": "@openagentsinc/three-effect",
  "version": "0.1.0",
  "description": "Effect and Foldkit bindings for resource-scoped Three.js scenes",
  "license": "Apache-2.0",
  "type": "module",
  "main": "packages/core/src/index.ts",
  "module": "packages/core/src/index.ts",
  "types": "packages/core/src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenAgentsInc/three-effect.git"
  },
  "homepage": "https://github.com/OpenAgentsInc/three-effect#readme",
  "bugs": {
    "url": "https://github.com/OpenAgentsInc/three-effect/issues"
  },
  "exports": {
    ".": {
      "types": "./packages/core/src/index.ts",
      "default": "./packages/core/src/index.ts"
    },
    "./core": {
      "types": "./packages/core/src/index.ts",
      "default": "./packages/core/src/index.ts"
    },
    "./foldkit": {
      "types": "./packages/foldkit/src/index.ts",
      "default": "./packages/foldkit/src/index.ts"
    }
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:demo:bezier": "bun build examples/bezier-nodes/src/main.ts --outdir examples/bezier-nodes/dist --target browser",
    "build:demo:moksha": "bun build examples/moksha/src/main.ts --outdir examples/moksha/dist --target browser && mkdir -p examples/moksha/dist/assets/moksha && cp packages/core/src/assets/moksha/* examples/moksha/dist/assets/moksha/",
    "build:demo:training": "bun build examples/training-run/src/main.ts --outdir examples/training-run/dist --target browser",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "bun run typecheck && bun test",
    "build:demo:hud": "bun build examples/hud-gallery/src/main.ts --outdir examples/hud-gallery/dist --target browser"
  },
  "keywords": [
    "three",
    "three.js",
    "effect",
    "foldkit",
    "webgl"
  ],
  "files": [
    "examples",
    "packages",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/three": "0.184.0",
    "effect": "4.0.0-beta.70",
    "foldkit": "0.102.1",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/bun": "1.1.14",
    "typescript": "6.0.3"
  }
}
